# ==============================================================================
# BEEPYRED NOC — Variables de Entorno
# Copiar este archivo a .env y completar con valores reales.
# NUNCA commitear el archivo .env con valores reales al repositorio.
# ==============================================================================

# -- Base de datos -------------------------------------------------------------
# Railway provee esta variable automaticamente al agregar el addon PostgreSQL.
# Formato: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/beepyred_noc

# -- Redis ---------------------------------------------------------------------
# Railway provee esta variable automaticamente al agregar el addon Redis.
# Formato: redis://default:password@host:6379
REDIS_URL=redis://localhost:6379

# -- Seguridad -----------------------------------------------------------------
# Generar SECRET_KEY con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Generar FERNET_KEY con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRITICO: Guardar en password manager. Sin esta key las credenciales de equipos son irrecuperables.
FERNET_KEY=CHANGE_ME_generate_with_Fernet_generate_key

# -- Tailscale VPN (INFRA-01) --------------------------------------------------
# Obtener en: https://login.tailscale.com/admin/settings/keys
# Crear auth key efimera con "Reusable" desactivado y "Ephemeral" activado para el worker.
# Solo el servicio "worker" de Railway necesita esta variable.
#
# DECISION TECNICA CONFIRMADA: Railway bloquea NET_ADMIN — WireGuard (kernel-mode,
# boringtun, wireguard-go) es imposible en Railway. Se usa Tailscale userspace
# (--tun=userspace-networking) con proxy SOCKS5 en localhost:1055.
# El Mikrotik con IP publica fija actua como Tailscale subnet router anunciando
# las rutas de la red ISP privada. Decision confirmada por el tecnico de BEEPYRED.
TAILSCALE_AUTH_KEY=tskey-auth-CHANGE_ME

# -- Telegram (Phase 3) --------------------------------------------------------
# Crear bot con @BotFather en Telegram. Obtener chat_id con @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -- Polling -------------------------------------------------------------------
POLL_INTERVAL_SECONDS=60
MAX_CONCURRENT_CONNECTIONS=50
DEVICE_TIMEOUT_SECONDS=10

# -- Umbrales de alerta (Phase 3) ----------------------------------------------
CPU_ALERT_THRESHOLD_PCT=90.0
ONU_SIGNAL_MIN_DBM=-28.0
CONSECUTIVE_FAILURES_THRESHOLD=3

# -- Deploy --------------------------------------------------------------------
# Railway auto-asigna PORT — no cambiar en produccion.
PORT=8000

# Dominio personalizado BEEPYRED (configuracion DNS en Railway dashboard — Phase 6).
# Ejemplo: noc.beepyred.com
CUSTOM_DOMAIN=
